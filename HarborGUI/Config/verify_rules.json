{
  "VerifyRules": [
    {
      "RuleName": "反斜杠检测",
      "Commands": ["$env:PYTHONUTF8 = \"1\""],
      "ExitCode": "0",
      "VerifyScript": "./backslash_detect.py ${Zip_Path}",
      "MatchResult": "0",
      "FailContinue": false,
      "ResultFormat":"\n检测项目:反斜杠检测\n检测结果:${Vaild_Result}\n检测详情:${Script_Output}"
    },
    {
      "RuleName": "文件完整性",
      "Commands": ["$env:PYTHONUTF8 = \"1\""],
      "ExitCode": "0",
      "VerifyScript": "./valid_file_exist.py",
      "MatchResult": "0",
      "FailContinue": false,
      "ResultFormat":"\n检测项目:文件完整性\n检测结果:${Vaild_Result}\n检测详情:${Script_Output}"
    },
    {
      "RuleName": "金标轨迹验证",
      "Commands": ["uv run --with harbor python -m harbor.utils.trajectory_validator ./golden-trajectory/agent/trajectory.json"],
      "ExitCode": "0",
      "VerifyScript": "",
      "MatchResult": "",
      "FailContinue": false,
      "ResultFormat":"\n检测项目:金标轨迹验证\n检测结果:${Vaild_Result}"
    },
    {
      "RuleName": "Agent/模型验证",
      "Commands": [],
      "ExitCode": "0",
      "VerifyScript": "./agent-name-detect.py",
      "MatchResult": "0",
      "FailContinue": false,
      "ResultFormat":"\n检测项目:Agent/模型验证\n检测结果:${Vaild_Result}\n检测详情:${Script_Output}"
    },
    {
      "RuleName": "模型通过率",
      "Commands": [],
      "ExitCode": "0",
      "VerifyScript": "./pass_rate.py models",
      "MatchResult": "(0,0.5]",
      "FailContinue": true,
      "ResultFormat":"\n检测项目:模型通过率\n检测结果:${Vaild_Result}\n通过率:${Script_Output}"
    },
    {
      "RuleName": "Docker构建",
      "Commands": ["docker build -t ${task.environment.docker_image} .\\environment\\"],
      "ExitCode": "0",
      "MatchResult": "",
      "FailContinue": false,
      "ResultFormat":"\n检测项目:Docker构建\n检测结果:${Vaild_Result}"
    },
    {
      "RuleName": "Oracle验证",
      "Commands": ["$env:PYTHONUTF8 = \"1\"", "harbor run -p . -a oracle"],
      "ExitCode": "0",
      "VerifyScript": "./pass_rate.py oracle",
      "MatchResult": "1.0",
      "FailContinue": true,
      "ResultFormat":"\n检测项目:Oracle验证\n检测结果:${Vaild_Result}\nReward:${Script_Output}"
    }
  ]
}