<Window x:Class="HarborGUI.Views.ExecutionLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="执行日志" Height="480" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="8"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="LogContent" FontFamily="Consolas" FontSize="12"
                          TextWrapping="NoWrap" Foreground="#333" Background="Transparent"
                          IsReadOnly="True" BorderThickness="0"
                          VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="关闭" Width="80" Height="32" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
